# Application
APP_PORT=3000
BACKEND_PORT=8000
JWT_SECRET=super-secret-dev-key-change-me
GOOGLE_API_KEY=your-google-api-key

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fiscal_assistant
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/fiscal_assistant

# Redis / Celery
REDIS_HOST=redis
REDIS_PORT=6379

# Oracle Object Storage (S3-compatible)
STORAGE_ENDPOINT=your-namespace.compat.objectstorage.your-region.oraclecloud.com
STORAGE_PUBLIC_ENDPOINT=your-namespace.compat.objectstorage.your-region.oraclecloud.com
STORAGE_ACCESS_KEY=your-oracle-access-key
STORAGE_SECRET_KEY=your-oracle-secret-key
STORAGE_BUCKET=fiscal-documents
STORAGE_SECURE=true
